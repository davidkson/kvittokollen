{
  "name": "willys-receipt-fetcher",
  "version": "1.0.0",
  "description": "Automatisk hämtning av digitala kvitton från Willys.se",
  "main": "fetch-receipts.js",
  "type": "module",
  "scripts": {
    "start": "node menu.cjs",
    "willys": "node fetch-receipts.js",
    "ica": "node fetch-ica-kivra.js",
    "install-browser": "npx playwright install chromium",
    "analyze-willys": "node reports/analyze-receipts.cjs",
    "analyze-ica": "node reports/analyze-ica.cjs",
    "analyze-combined": "node reports/analyze-combined.cjs",
    "update-willys": "node scripts/update-receipts.cjs",
    "update-ica": "node scripts/update-ica.cjs",
    "remove-duplicates": "node scripts/remove-duplicates.cjs",
    "sync-willys": "node fetch-receipts.js && node scripts/update-receipts.cjs",
    "sync-ica": "node fetch-ica-kivra.js && node scripts/update-ica.cjs",
    "sync-all": "npm run sync-willys && npm run sync-ica"
  },
  "keywords": [
    "willys",
    "receipts",
    "kvitton"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.48.0"
  }
}
